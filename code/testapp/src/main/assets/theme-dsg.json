  "behavior": {
    "multimodalCarousel": {
      "cardClickAction": "openLink",
      "carouselStyle": "scroll"
    },
    "productCard": {
      "cardStyle": "productDetail",
      "cardsAlignment": "start"
    },
    "input": {
      "enableVoiceInput": true,
      "sendButtonStyle": "arrow",
      "disableMultiline": false,
      "showAiChatIcon": null
