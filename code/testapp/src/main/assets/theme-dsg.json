    "chat": {
      "messageAlignment": "left",
      "messageWidth": "100%",
      "userMessageBubbleStyle": "balloon"
    },
    "privacyNotice": {
      "title": "Privacy Notice",
      "text": "Privacy notice text."
    },
    "feedback": {
      "displayMode": "action",
      "thumbsPlacement": "below"
    },
    "citations": {
      "showLinkIcon": true
    },
    "welcomeCard": {
      "closeButtonAlignment": "start",
      "promptFullWidth": false,
      "promptMaxLines": 2,
      "contentAlignment": "top"
    },
    "promptSuggestions": {
      "itemMaxLines": 1,
      "showHeader": true
    }
  },
