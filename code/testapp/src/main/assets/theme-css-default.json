{
  "metadata": {
    "name": "CSS Default Theme",
    "version": "1.0.0",
    "author": "Adobe",
    "description": "Default theme with CSS variables"
  },
  "behavior": {
    "enableDarkMode": true,
    "enableAnimations": true,
    "enableVoiceInput": true
  },
  "theme": {
    "--font-family": "\"Adobe Clean\", sans-serif",
    "--line-height-body": "1.5",
    "--color-primary": "#EB1000",
    "--color-text": "#2C2C2C",
    "--main-container-background": "#FFFFFF",
    "--main-container-bottom-background": "#F5F5F5",
    "--message-blocker-background": "linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #FFFFFF 100%)",
    "--message-user-background": "#EB1000",
    "--message-user-text": "#FFFFFF",
    "--message-concierge-background": "#F5F5F5",
    "--message-concierge-text": "#2C2C2C",
    "--message-concierge-link-color": "#1473E6",
    "--button-primary-background": "#EB1000",
    "--button-primary-text": "#FFFFFF",
    "--button-primary-hover": "#D10000",
    "--button-secondary-border": "#EB1000",
    "--button-secondary-text": "#EB1000",
    "--button-secondary-hover": "#FEF7F6",
    "--color-button-secondary-hover-text": "#D10000",
    "--submit-button-fill-color": "#EB1000",
    "--submit-button-fill-color-disabled": "#E1E1E1",
    "--color-button-submit": "#FFFFFF",
    "--color-button-submit-hover": "#FFFFFF",
    "--button-disabled-background": "#E1E1E1",
    "--input-background": "#FFFFFF",
    "--input-text-color": "#2C2C2C",
    "--input-outline-color": "linear-gradient(90deg, #FF0000 0%, #FF8800 100%)",
    "--input-focus-outline-color": "#EB1000",
    "--feedback-icon-btn-background": "#F5F5F5",
    "--feedback-icon-btn-hover-background": "#E1E1E1",
    "--disclaimer-color": "#6E6E6E",
    "--input-height-mobile": "52px",
    "--input-border-radius-mobile": "12px",
    "--input-outline-width": "2px",
    "--input-focus-outline-width": "2px",
    "--input-font-size": "16px",
    "--input-button-height": "32px",
    "--input-button-width": "32px",
    "--input-button-border-radius": "8px",
    "--input-box-shadow": "0 2px 8px rgba(0, 0, 0, 0.1)",
    "--message-border-radius": "10px",
    "--message-padding": "12px 16px",
    "--message-max-width": "85%",
    "--chat-interface-max-width": "768px",
    "--chat-history-padding": "16px",
    "--chat-history-padding-top-expanded": "0px",
    "--chat-history-bottom-padding": "0px",
    "--message-blocker-height": "105px",
    "--border-radius-card": "16px",
    "--multimodal-card-box-shadow": "0 4px 16px rgba(0, 0, 0, 0.12)",
    "--button-height-s": "30px",
    "--feedback-container-gap": "4px",
    "--citations-text-font-weight": "500",
    "--citations-desktop-button-font-size": "14px",
    "--disclaimer-font-size": "12px",
    "--disclaimer-font-weight": "400",
    "--welcome-input-order": "2",
    "--welcome-cards-order": "1",
    "--feedback-icon-btn-size-desktop": "32px"
  }
}

