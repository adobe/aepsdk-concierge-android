{
  "metadata": {
    "brandName": "Test Implementation",
    "version": "1.0.0",
    "language": "en-US",
    "namespace": "test-implementation"
  },
  "behavior": {
    "enableVoiceInput": true,
    "enableFeedback": true,
    "enableCitations": true,
    "enableAnimations": true
  },
  "disclaimer": {
    "text": "AI responses may be inaccurate. Check answers and sources. {Terms}",
    "links": [
      {
        "text": "Terms",
        "url": "https://www.adobe.com/legal/licenses-terms/adobe-gen-ai-user-guidelines.html"
      }
    ]
  },
  "text": {
    "welcome.heading": "Test Theme - Implementation Demo",
    "welcome.subheading": "This theme demonstrates:\n• Custom line height (1.5)\n• Visible input borders (gray unfocused, blue focused)\n• Behavior toggles (voice input, feedback)\n• Typography adjustments",
    "input.placeholder": "Type here to test focus borders...",
    "error.network": "Network error occurred.",
    "loading.message": "Generating response...",
    "feedback.dialog.title.positive": "Your feedback is appreciated",
    "feedback.dialog.title.negative": "Your feedback is appreciated",
    "feedback.dialog.question.positive": "What went well?",
    "feedback.dialog.question.negative": "What went wrong?",
    "feedback.dialog.notes": "Notes",
    "feedback.dialog.submit": "Submit",
    "feedback.dialog.cancel": "Cancel",
    "feedback.dialog.notes.placeholder": "Additional notes (optional)",
    "feedback.toast.success": "Thank you for the feedback."
  },
  "arrays": {
    "welcome.examples": [
      {
        "text": "Test line height in messages by sending this prompt.",
        "backgroundColor": "#E8F5E9"
      },
      {
        "text": "Test input border by clicking this to focus the input field.",
        "backgroundColor": "#E3F2FD"
      },
      {
        "text": "Test feedback buttons by sending a message and checking the thumbs up/down icons.",
        "backgroundColor": "#FFF3E0"
      }
    ],
    "feedback.positive.options": [
      "Helpful",
      "Clear",
      "Other"
    ],
    "feedback.negative.options": [
      "Unclear",
      "Unhelpful",
      "Other"
    ]
  },
  "assets": {
    "icons": {
      "company": ""
    }
  },
  "theme": {
    "comment": "Typography - Line Height (IMPLEMENTED)",
    "--line-height-body": "1.5",
    
    "comment2": "Input Borders (IMPLEMENTED)",
    "--input-outline-width": "2px",
    "--input-outline-color": "#9E9E9E",
    "--input-focus-outline-width": "3px",
    "--input-focus-outline-color": "#2196F3",
    
    "comment3": "Font Family (PARSED BUT NOT APPLIED)",
    "--font-family": "Roboto",
    
    "comment4": "Welcome Order (PARSED BUT NOT APPLIED)",
    "--welcome-input-order": "2",
    "--welcome-cards-order": "3",
    
    "comment5": "Colors",
    "--color-primary": "#2196F3",
    "--color-text": "#212121",
    "--main-container-background": "#FAFAFA",
    "--main-container-bottom-background": "#FFFFFF",
    
    "comment6": "Input styling",
    "--input-height-mobile": "52px",
    "--input-border-radius-mobile": "12px",
    "--input-background": "#FFFFFF",
    "--input-box-shadow": "0 1px 3px 0 rgba(0,0,0,0.1)",
    "--input-font-size": "16px",
    "--input-text-color": "#212121",
    "--input-button-height": "32px",
    "--input-button-width": "32px",
    "--input-button-border-radius": "8px",
    
    "comment7": "Button colors",
    "--submit-button-fill-color": "#2196F3",
    "--submit-button-fill-color-disabled": "#BDBDBD",
    "--color-button-submit": "#FFFFFF",
    "--button-disabled-background": "#F5F5F5",
    
    "comment8": "Message styling",
    "--message-user-background": "#E3F2FD",
    "--message-user-text": "#1565C0",
    "--message-concierge-background": "#F5F5F5",
    "--message-concierge-text": "#424242",
    "--message-border-radius": "12px",
    "--message-padding": "12px 16px",
    "--message-concierge-link-color": "#1976D2",
    
    "comment9": "Disclaimer",
    "--disclaimer-color": "#757575",
    "--disclaimer-font-size": "12px",
    "--disclaimer-font-weight": "400",
    
    "comment10": "Feedback",
    "--feedback-icon-btn-background": "#FAFAFA",
    "--feedback-icon-btn-hover-background": "#EEEEEE",
    "--feedback-icon-btn-size-desktop": "32px",
    "--feedback-container-gap": "8px",
    
    "comment11": "Layout",
    "--chat-interface-max-width": "768px",
    "--chat-history-padding": "16px",
    "--border-radius-card": "12px",
    "--button-height-s": "32px",
    
    "comment12": "Primary button",
    "--button-primary-background": "#2196F3",
    "--button-primary-text": "#FFFFFF",
    "--button-primary-hover": "#1976D2",
    
    "comment13": "Secondary button",
    "--button-secondary-border": "#757575",
    "--button-secondary-text": "#424242",
    "--button-secondary-hover": "#424242",
    "--color-button-secondary-hover-text": "#FFFFFF"
  }
