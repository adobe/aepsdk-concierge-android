{
  "metadata": {
    "brandName": "No Voice/Feedback Demo",
    "version": "1.0.0",
    "language": "en-US",
    "namespace": "test-behavior-disabled"
  },
  "behavior": {
    "multimodalCarousel": {
      "cardClickAction": "openLink"
    },
    "input": {
      "enableVoiceInput": false,
      "disableMultiline": false,
      "showAiChatIcon": null
    },
    "chat": {
      "messageAlignment": "left",
      "messageWidth": "100%"
    },
    "privacyNotice": {
      "title": "Privacy Notice",
      "text": "Privacy notice text."
    }
  },
  "disclaimer": {
    "text": "AI responses may be inaccurate. Check answers and sources. {Terms}",
    "links": [
      {
        "text": "Terms",
        "url": "https://www.adobe.com/legal/licenses-terms/adobe-gen-ai-user-guidelines.html"
      }
    ]
  },
  "text": {
    "welcome.heading": "Behavior Test: Voice Input Disabled",
    "welcome.subheading": "This theme demonstrates behavior toggles:\n• Voice input DISABLED (no mic button)\n• Only send button visible in input area\n• Feedback buttons still available\n• Citations enabled",
    "input.placeholder": "No mic button - only text input...",
    "error.network": "Network error occurred.",
    "loading.message": "Generating response...",
    "feedback.dialog.title.positive": "Your feedback is appreciated",
    "feedback.dialog.title.negative": "Your feedback is appreciated",
    "feedback.dialog.question.positive": "What went well?",
    "feedback.dialog.question.negative": "What went wrong?",
    "feedback.dialog.notes": "Notes",
    "feedback.dialog.submit": "Submit",
    "feedback.dialog.cancel": "Cancel",
    "feedback.dialog.notes.placeholder": "Additional notes (optional)",
    "feedback.toast.success": "Thank you for the feedback."
  },
  "arrays": {
    "welcome.examples": [
      {
        "text": "Notice: No microphone button in the input area!",
        "backgroundColor": "#FFEBEE"
      },
      {
        "text": "Send a message - feedback buttons are still available",
        "backgroundColor": "#FCE4EC"
      },
      {
        "text": "Citations still work when available",
        "backgroundColor": "#F3E5F5"
      }
    ],
    "feedback.positive.options": [
      "Helpful",
      "Clear",
      "Other"
    ],
    "feedback.negative.options": [
      "Unclear",
      "Unhelpful",
      "Other"
    ]
  },
  "assets": {
    "icons": {
      "company": ""
    }
  },
  "theme": {
    "--line-height-body": "1.6",
    "--color-primary": "#D32F2F",
    "--color-text": "#212121",
    "--main-container-background": "#FAFAFA",
    "--main-container-bottom-background": "#FFFFFF",
    "--input-height-mobile": "52px",
    "--input-border-radius-mobile": "12px",
    "--input-background": "#FFFFFF",
    "--input-outline-width": "2px",
    "--input-outline-color": "#FFCDD2",
    "--input-focus-outline-width": "2px",
    "--input-focus-outline-color": "#D32F2F",
    "--input-box-shadow": "0 1px 3px 0 rgba(0,0,0,0.1)",
    "--input-font-size": "16px",
    "--input-text-color": "#212121",
    "--input-button-height": "32px",
    "--input-button-width": "32px",
    "--input-button-border-radius": "8px",
    "--submit-button-fill-color": "#D32F2F",
    "--submit-button-fill-color-disabled": "#BDBDBD",
    "--color-button-submit": "#FFFFFF",
    "--button-disabled-background": "#F5F5F5",
    "--message-user-background": "#FFCDD2",
    "--message-user-text": "#C62828",
    "--message-concierge-background": "#F5F5F5",
    "--message-concierge-text": "#424242",
    "--message-border-radius": "12px",
    "--message-padding": "12px 16px",
    "--message-concierge-link-color": "#D32F2F",
    "--disclaimer-color": "#757575",
    "--disclaimer-font-size": "12px",
    "--disclaimer-font-weight": "400",
    "--chat-interface-max-width": "768px",
    "--chat-history-padding": "16px",
    "--border-radius-card": "12px",
    "--button-height-s": "32px",
    "--button-primary-background": "#D32F2F",
    "--button-primary-text": "#FFFFFF",
    "--button-primary-hover": "#C62828",
    "--button-secondary-border": "#757575",
    "--button-secondary-text": "#424242",
    "--button-secondary-hover": "#424242",
    "--color-button-secondary-hover-text": "#FFFFFF"
  }
}
